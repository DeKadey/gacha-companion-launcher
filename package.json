{
  "name": "gacha-companion",
  "version": "1.0.0",
  "description": "Personal gacha game companion",
  "main": "electron/main.js",
  "homepage": "./",
  "scripts": {
    "react-build": "react-scripts build",
    "start": "electron .",
    "build-exe": "npm run react-build && electron-builder --win --x64",
    "publish": "npm run react-build && electron-builder --win --x64 --publish always",
    "dev": "concurrently \"cross-env BROWSER=none react-scripts start\" \"wait-on http://localhost:3000 && electron .\""
  },
  "dependencies": {
    "electron-updater": "^6.1.7",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "genshin-db": "^5.2.11",
    "koffi": "^3.0.2",
    "lucide-react": "^0.383.0",
    "motion": "^12.40.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4",
    "playwright-core": "^1.60.0",
    "wait-on": "^7.2.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version"
    ]
  },
  "build": {
    "appId": "com.you.gacha-companion",
    "productName": "Gacha Companion",
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "node_modules/genshin-db/**/*",
      "node_modules/xlsx/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "DeKadey",
      "repo": "gacha-companion-launcher",
      "releaseType": "release"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "GachaCompanion-Setup.exe"
    }
  }
}
